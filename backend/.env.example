# Backend environment variables
# Copy to .env and fill in values:  cp .env.example .env

# ── Modal LLM endpoint (REQUIRED) ──────────────────────────────
# This is the URL of the deployed Modal LLM service
MODAL_LLM_URL=https://dkmist08--stylevector-llm-api.modal.run

# ── MongoDB Atlas (OPTIONAL — chat history won't persist without it) ──
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
# MONGODB_DB=stylevector

# ── Server config ──────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=true
LLM_TIMEOUT_SECONDS=180

# ── CORS origins (comma-separated) ────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
