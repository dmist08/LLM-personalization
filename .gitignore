# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual Environments ────────────────────────────────
.venv/
venv/
env/
.conda/

# ── IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Data (too large for git) ────────────────────────────
data/raw/
data/processed/
data/splits/
data/interim/
*.parquet
*.npy
*.pkl
*.h5

# ── Models (too large for git) ──────────────────────────
models/
*.pt
*.pth
*.bin
*.safetensors
*.gguf

# ── Checkpoints (too large for git) ─────────────────────
checkpoints/
# Allow LoRA adapter (small, ~70MB, needed for reproducibility)
!checkpoints/lora/final/

# ── Author Vectors (generated, regenerated per run) ─────
author_vectors/

# ── Logs ────────────────────────────────────────────────
logs/
*.log
wandb/

# ── Outputs (regenerated per run) ───────────────────────
outputs/
# Keep evaluation results (small, needed for paper)
!outputs/evaluation/

# ── Docs (KEEP — plans, research paper) ─────────────────
# Do NOT ignore docs/ — it has the canonical project plan
# But ignore chat log exports (large JSON)
docs/dev_chat_logs/
docs/COLD_START_STYLEVECTOR_V3.md

# ── OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Secrets ─────────────────────────────────────────────
.env
*.key

# ── Jupyter ─────────────────────────────────────────────
.ipynb_checkpoints/

# ── Scraping artifacts (keep code, ignore data) ─────────
scraping/**/*.bak
scraping/**/*.bak.jsonl

# ── Antigravity agent ───────────────────────────────────
.gemini/
